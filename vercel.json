{
  "version": 2,
  "builds": [
    { "src": "api/parse.js", "use": "@vercel/node" },
    { "src": "api/submit.js", "use": "@vercel/node" },
    { "src": "api/orders.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/parse", "dest": "/api/parse.js" },
    { "src": "/api/submit", "dest": "/api/submit.js" },
    { "src": "/api/orders", "dest": "/api/orders.js" },
    { "handle": "filesystem" },
    { "src": "/order", "dest": "/order.html" },
    { "src": "/dashboard", "dest": "/dashboard.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
